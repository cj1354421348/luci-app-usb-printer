msgid "Multi-Printer Server"
msgstr "多打印机服务器"

msgid "USB Printer Server"
msgstr "USB 打印服务器"

msgid ""
"Shares multiple USB printers via TCP/IP.<br />"
"When modified bingings, re-plug usb connectors to take effect.<br />"
"This module requires kmod-usb-printer."
msgstr ""
"通过 TCP/IP 共享多台 USB 打印机。<br />"
"修改绑定关系后，请重新插拔打印机 USB 连接线以使设置生效。<br />"
"此模块需要安装 kmod-usb-printer 驱动。"

msgid "Detected printers"
msgstr "已检测到的打印机"

msgid "Description"
msgstr "描述"

msgid "Printer Model"
msgstr "打印机型号"

msgid "VID/PID"
msgstr "厂商/产品 ID"

msgid "Device Name"
msgstr "设备名称"

msgid "Bindings"
msgstr "端口绑定"

msgid "enable"
msgstr "启用"

msgid "Device"
msgstr "设备标识"

msgid "Interface"
msgstr "网络接口"

msgid "Specifies the interface to listen on."
msgstr "指定打印服务监听的网络接口。"

msgid "Port"
msgstr "端口"

msgid "TCP listener port."
msgstr "TCP 监听端口号。"

msgid "Bidirectional mode"
msgstr "双向通信模式"
